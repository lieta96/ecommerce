{{!-- enctype multipart: permite enviar archivos junto al resto de los campos --}}

<section class="product-form-page">
  <header class="product-form-page__header">
    <h1 class="product-form-page__title">Agregar producto</h1>
    <p class="product-form-page__subtitle">
      Completá los datos y subí una imagen opcional. Los productos se guardan en el listado.
    </p>
  </header>

  <div class="product-form-card">
    <form
      class="product-form"
      action="/api/products"
      method="post"
      enctype="multipart/form-data"
    >
      <div class="product-form__field">
        <label class="product-form__label" for="product-title">Título</label>
        <input
          class="product-form__input"
          id="product-title"
          type="text"
          name="title"
          required
          autocomplete="off"
          placeholder="Ej. Astronauta"
        />
      </div>

      <div class="product-form__field">
        <label class="product-form__label" for="product-description">Descripción</label>
        <textarea
          class="product-form__textarea"
          id="product-description"
          name="description"
          rows="3"
          placeholder="Detalle breve del producto"
        ></textarea>
      </div>
      <div class="product-form__field">
        <label class="product-form__label" for="product-category">Categoría</label>
        <input
          class="product-form__input"
          id="product-category"
          name="category"
          placeholder="Categoría del producto"
        />
      </div>

      <div class="product-form__row">
        <div class="product-form__field">
          <label class="product-form__label" for="product-price">Precio</label>
          <input
            class="product-form__input"
            id="product-price"
            type="number"
            name="price"
            min="0"
            step="any"
            required
            placeholder="0"
          />
        </div>
        <div class="product-form__field">
          <label class="product-form__label" for="product-stock">Stock</label>
          <input
            class="product-form__input"
            id="product-stock"
            type="number"
            name="stock"
            min="0"
            step="1"
            placeholder="0"
          />
        </div>
      </div>

      <div class="product-form__field">
        <span class="product-form__label" id="product-image-label">Imagen</span>
        <label class="product-form__file">
          <input
            class="product-form__file-input"
            type="file"
            name="thumbnail"
            accept="image/*"
            aria-labelledby="product-image-label"
          />
          <span class="product-form__file-text">Elegir archivo…</span>
        </label>
        <p class="product-form__hint">Formatos de imagen habituales (JPG, PNG, WebP).</p>
      </div>

      <div class="product-form__actions">
        <button class="product-form__submit" type="submit">Guardar producto</button>
      </div>
    </form>
  </div>
</section>
