<section class="product-detail-page">
  <header class="product-detail-page__header">
    <p class="product-detail-page__eyebrow">Producto</p>
    <h1 class="product-detail-page__title">{{productTitle}}</h1>
    {{#if category}}
      <p class="product-detail-page__category">{{category}}</p>
    {{/if}}
  </header>

  <article class="product-detail{{#unless thumbnails.length}} product-detail--data-only{{/unless}}">
    {{#if thumbnails.length}}
      <div class="product-detail__gallery" aria-label="Imágenes del producto">
        {{#each thumbnails}}
          <figure class="product-detail__figure">
            <img
              class="product-detail__img"
              src="/images/{{this}}"
              alt="{{../productTitle}}"
              loading="lazy"
            />
          </figure>
        {{/each}}
      </div>
    {{/if}}

    <div class="product-detail__panel">
      {{#if description}}
        <p class="product-detail__desc">{{description}}</p>
      {{/if}}

      {{#if code}}
        <p class="product-detail__code"><span class="product-detail__code-label">Código</span> {{code}}</p>
      {{/if}}

      <div class="product-detail__meta">
        <span class="product-detail__price">${{price}}</span>
        <span class="product-detail__stock">{{stock}} u.</span>
      </div>

      <div class="product-detail__actions">
        <button
          type="button"
          class="product-detail__btn"
          data-pid="{{_id}}"
          data-cid="{{cid}}"
          data-action="add"
          onclick="addToCart(this)"
        >
          Agregar al carrito
        </button>
      </div>

      <a href="/products" class="product-detail__back">← Volver al catálogo</a>
    </div>
  </article>
</section>
