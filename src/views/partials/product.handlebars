<article class="product-card">

  {{#each thumbnails}}
    <div class="product-card__media">
      <img
        class="product-card__img"
        src="/images/{{this}}"
        alt=""
        loading="lazy"
      /></div>
  {{else}}

  {{/each}}

  <div class="product-card__body">
    <h2 class="product-card__title">{{title}}</h2>
   
    <div class="product-card__meta">
      <span class="product-card__price">${{price}}</span>
      <span class="product-card__stock">{{stock}} u.</span>
    </div>
    <a href="/products/{{_id}}" class="product-card__link">Ver producto</a>
    <div>
      {{! A qué carrito lo agregamos? Crear un carrito cuando se preciona agregar al carrito y mantenerlo en la sesión actual }}
      <button data-pid="{{_id}}"
      data-cid="{{cid}}"
      data-action="add"
      class="product-card__button"     
      onclick="addToCart(this)"
      >
        Agregar al carrito
      </button>
    </div>
  </div>
</article>