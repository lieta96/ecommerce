<article class="product-card">
  {{#each thumbnails}}
    <div class="product-card__media">
      <img
        class="product-card__img"
        src="/images/{{this}}"
        alt=""
        loading="lazy"
      /></div>
  {{else}}
  {{/each}}
  <div class="product-card__body">
    <a href="/products/{{_id}}?cid={{@root.cid}}" class="product-card__link">
      <h2 class="product-card__title">{{title}}</h2></a>

    <div class="product-card__meta">
      <span class="product-card__price">${{price}}</span>
      <span class="product-card__stock">{{stock}} u.</span>
    </div>
    <div>
    </div>
    <form>
      <button
        data-cid="{{@root.cid}}"
        class="product-card__button"
        data-pid="{{_id}}"
        type="submit"
      >Agregar al carrito</button>
    </form>
  </div>
</article>